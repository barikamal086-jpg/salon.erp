# Railway PostgreSQL Configuration
# Copie para .env e preencha com seus valores

# Database Connection String (obtido do Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/salon_erp_db

# Ambiente
NODE_ENV=production

# Porta da API
PORT=5006

# JWT Secret (para autenticação futura)
JWT_SECRET=seu_secret_jwt_aqui

# Log Level
LOG_LEVEL=info
